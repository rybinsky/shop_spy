{
  "manifest_version": 3,
  "name": "ShopSpy - Умный помощник покупателя",
  "version": "0.2.0",
  "description": "AI-помощник для покупок на WB и Ozon. История цен, разоблачение фейковых скидок, AI-анализ отзывов, сравнение площадок.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.wildberries.ru/*",
    "https://wildberries.ru/*",
    "https://www.ozon.ru/*",
    "https://ozon.ru/*",
    "https://shop-spy-docker.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.wildberries.ru/*",
        "https://wildberries.ru/*"
      ],
      "js": ["content/shared.js", "content/wb.js"],
      "css": ["content/shopspy.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ozon.ru/*",
        "https://ozon.ru/*"
      ],
      "js": ["content/shared.js", "content/ozon.js"],
      "css": ["content/shopspy.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ShopSpy"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
