# ─────────────────────────────────────────────────
# ShopSpy — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────

# ── Required ──────────────────────────────────────

# "development" | "production" | "testing"
ENVIRONMENT=development

# ── Telegram Bot (optional, enables notifications) ─
TELEGRAM_BOT_TOKEN=

# ── AI Review Analysis (optional, at least one) ───
# Gemini (free tier — recommended)
GEMINI_API_KEY=
# Claude (paid, used as fallback if Gemini is not set)
ANTHROPIC_API_KEY=

# ── Server ────────────────────────────────────────
# Render.com sets PORT automatically; locally defaults to 8000
# HOST=0.0.0.0
# PORT=8000
# DEBUG=false

# ── AI Tuning (optional) ─────────────────────────
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MAX_TOKENS=4000
# GEMINI_TEMPERATURE=0.3
# RATE_LIMIT_PER_IP=10
# RATE_LIMIT_GLOBAL=200
